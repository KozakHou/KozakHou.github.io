{% if site.enable_google_verification or site.enable_bing_verification %}
  <!-- Website verification -->
  {% if site.enable_google_verification %}
    <meta name="google-site-verification" content="{{ site.google_site_verification }}">
  {% endif %}
  {% if site.enable_bing_verification %}
    <meta name="msvalidate.01" content="{{ site.bing_site_verification }}">
  {% endif %}
  <!--
    Avoid warning on Google Chrome Error with Permissions-Policy header:
    Origin trial controlled feature not enabled: 'interest-cohort'.
    see https://stackoverflow.com/a/75119417
  -->
  <meta http-equiv="Permissions-Policy" content="interest-cohort=()">
{% endif %}

{% assign resume_basics = site.data.resume.basics %}
{% capture author_name %}{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}{% endcapture %}
{% assign person_name = site.person.name | default: resume_basics.name | default: author_name | strip %}
{% assign site_name = site.title %}
{% if site.title == 'blank' or site.title == blank %}
  {% assign site_name = person_name %}
{% endif %}

{% assign is_blog_post = false %}
{% if page.collection == 'posts' %}
  {% assign is_blog_post = true %}
{% endif %}

{% assign is_project_page = false %}
{% if page.collection == 'projects' %}
  {% assign is_project_page = true %}
{% endif %}

{% assign page_url_downcase = page.url | downcase %}
{% assign canonical_url = page.url | replace: 'index.html', '' | absolute_url %}
{% assign meta_description = page.description | default: site.description | strip_html | strip_newlines | strip %}
{% assign meta_keywords = page.keywords | default: site.keywords %}
{% assign robots_content = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1' %}
{% if page.noindex %}
  {% assign robots_content = 'noindex,nofollow' %}
{% endif %}

{% assign meta_title = site_name %}
{% if page.seo_title and page.seo_title != blank %}
  {% assign meta_title = page.seo_title %}
{% elsif page.url == '/' or page.permalink == '/' %}
  {% assign meta_title = person_name %}
{% elsif page.title and page.title != blank and page.title != 'blank' %}
  {% assign meta_title = page.title | append: ' | ' | append: person_name %}
{% endif %}

{% assign page_headline = page.title | default: person_name %}
{% if page.url == '/' or page.permalink == '/' %}
  {% assign page_headline = person_name %}
{% endif %}

{% assign og_type = 'website' %}
{% if page.url == '/' or page.permalink == '/' %}
  {% assign og_type = 'profile' %}
{% elsif is_blog_post or is_project_page %}
  {% assign og_type = 'article' %}
{% endif %}

{% assign schema_page_type = 'WebPage' %}
{% if page.url == '/' or page.permalink == '/' %}
  {% assign schema_page_type = 'ProfilePage' %}
{% elsif page.url == '/projects/' or page.url == '/publications/' or page_url_downcase == '/repositories/' %}
  {% assign schema_page_type = 'CollectionPage' %}
{% elsif page_url_downcase == '/cv/' %}
  {% assign schema_page_type = 'ProfilePage' %}
{% elsif is_project_page %}
  {% assign schema_page_type = 'TechArticle' %}
{% elsif is_blog_post %}
  {% assign schema_page_type = 'BlogPosting' %}
{% endif %}

{% assign meta_image_value = page.og_image | default: page.img | default: site.og_image %}
{% assign meta_image_url = '' %}
{% if meta_image_value != blank %}
  {% assign meta_image_first_char = meta_image_value | slice: 0, 1 %}
  {% if meta_image_value contains '://' %}
    {% assign meta_image_url = meta_image_value %}
  {% elsif meta_image_first_char == '/' %}
    {% assign meta_image_url = meta_image_value | absolute_url %}
  {% else %}
    {% assign meta_image_url = '/' | append: meta_image_value | absolute_url %}
  {% endif %}
{% endif %}

{% assign person_image_value = site.person.image | default: site.og_image %}
{% assign person_image_url = '' %}
{% if person_image_value != blank %}
  {% assign person_image_first_char = person_image_value | slice: 0, 1 %}
  {% if person_image_value contains '://' %}
    {% assign person_image_url = person_image_value %}
  {% elsif person_image_first_char == '/' %}
    {% assign person_image_url = person_image_value | absolute_url %}
  {% else %}
    {% assign person_image_url = '/' | append: person_image_value | absolute_url %}
  {% endif %}
{% endif %}

{% assign same_as = '' | split: '' %}
{% if site.github_username %}
  {% capture profile_url %}https://github.com/{{ site.github_username }}{% endcapture %}
  {% assign same_as = same_as | push: profile_url %}
{% endif %}
{% if site.linkedin_username %}
  {% capture profile_url %}https://www.linkedin.com/in/{{ site.linkedin_username }}{% endcapture %}
  {% assign same_as = same_as | push: profile_url %}
{% endif %}
{% if site.orcid_id %}
  {% capture profile_url %}https://orcid.org/{{ site.orcid_id }}{% endcapture %}
  {% assign same_as = same_as | push: profile_url %}
{% endif %}
{% if site.scholar_userid %}
  {% capture profile_url %}https://scholar.google.com/citations?user={{ site.scholar_userid }}{% endcapture %}
  {% assign same_as = same_as | push: profile_url %}
{% endif %}
{% if site.research_gate_profile %}
  {% capture profile_url %}https://www.researchgate.net/profile/{{ site.research_gate_profile }}{% endcapture %}
  {% assign same_as = same_as | push: profile_url %}
{% endif %}
{% if resume_basics and resume_basics.profiles %}
  {% for profile in resume_basics.profiles %}
    {% if profile.url and profile.url != blank %}
      {% unless same_as contains profile.url %}
        {% assign same_as = same_as | push: profile.url %}
      {% endunless %}
    {% endif %}
  {% endfor %}
{% endif %}

<!-- Standard metadata -->
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>{{ meta_title | escape_once }}</title>
<meta name="author" content="{{ person_name | escape_once }}">
<meta name="description" content="{{ meta_description | escape_once }}">
<meta name="robots" content="{{ robots_content }}">
{% if meta_keywords and meta_keywords != blank %}
  <meta name="keywords" content="{{ meta_keywords | strip | escape_once }}">
{% endif %}

{% if site.serve_og_meta %}
  <!-- OpenGraph -->
  <meta property="og:site_name" content="{{ site_name | escape_once }}">
  <meta property="og:type" content="{{ og_type }}">
  <meta property="og:title" content="{{ meta_title | escape_once }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:description" content="{{ meta_description | escape_once }}">
  {% if meta_image_url != blank %}
    <meta property="og:image" content="{{ meta_image_url }}">
    <meta property="og:image:secure_url" content="{{ meta_image_url }}">
    <meta property="og:image:alt" content="{{ page_headline | escape_once }}">
  {% endif %}
  <meta property="og:locale" content="{{ site.lang }}">
  {% if page.url == '/' or page.permalink == '/' %}
    <meta property="profile:first_name" content="Po-Han">
    <meta property="profile:last_name" content="Hou">
  {% endif %}
  {% if is_blog_post and page.date %}
    <meta property="article:published_time" content="{{ page.date | date_to_xmlschema }}">
  {% endif %}

  <!-- Twitter card -->
  <meta name="twitter:card" content="{% if meta_image_url != blank %}summary_large_image{% else %}summary{% endif %}">
  <meta name="twitter:title" content="{{ meta_title | escape_once }}">
  <meta name="twitter:description" content="{{ meta_description | escape_once }}">
  {% if meta_image_url != blank %}
    <meta name="twitter:image" content="{{ meta_image_url }}">
    <meta name="twitter:image:alt" content="{{ page_headline | escape_once }}">
  {% endif %}
  {% if site.x_username %}
    <meta name="twitter:site" content="@{{ site.x_username }}">
    <meta name="twitter:creator" content="@{{ site.x_username }}">
  {% endif %}
{% endif %}

{% if site.serve_schema_org %}
  <!-- Schema.org -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": {{ site.url | append: '/#person' | jsonify }},
      "name": {{ person_name | jsonify }},
      "url": {{ site.url | jsonify }},
      "description": {{ site.description | strip_html | strip_newlines | strip | jsonify }}{% if person_image_url != blank %},
      "image": {{ person_image_url | jsonify }}{% endif %}{% if site.person.job_title %},
      "jobTitle": {{ site.person.job_title | jsonify }}{% endif %}{% if site.email %},
      "email": {{ site.email | prepend: 'mailto:' | jsonify }}{% endif %}{% if site.person.alternate_names and site.person.alternate_names.size > 0 %},
      "alternateName": {{ site.person.alternate_names | jsonify }}{% endif %}{% if same_as.size > 0 %},
      "sameAs": {{ same_as | jsonify }}{% endif %}{% if site.person.knows_about and site.person.knows_about.size > 0 %},
      "knowsAbout": {{ site.person.knows_about | jsonify }}{% endif %}{% if site.person.affiliations and site.person.affiliations.size > 0 %},
      "affiliation": [{% for org in site.person.affiliations %}{ "@type": "Organization", "name": {{ org | jsonify }} }{% unless forloop.last %}, {% endunless %}{% endfor %}]{% endif %}{% if site.person.alumni_of and site.person.alumni_of.size > 0 %},
      "alumniOf": [{% for org in site.person.alumni_of %}{ "@type": "CollegeOrUniversity", "name": {{ org | jsonify }} }{% unless forloop.last %}, {% endunless %}{% endfor %}]{% endif %}
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": {{ site.url | append: '/#website' | jsonify }},
      "url": {{ site.url | jsonify }},
      "name": {{ site_name | jsonify }},
      "description": {{ site.description | strip_html | strip_newlines | strip | jsonify }},
      "inLanguage": {{ site.lang | jsonify }},
      "author": { "@id": {{ site.url | append: '/#person' | jsonify }} },
      "publisher": { "@id": {{ site.url | append: '/#person' | jsonify }} }
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": {{ schema_page_type | jsonify }},
      "@id": {{ canonical_url | append: '#webpage' | jsonify }},
      "url": {{ canonical_url | jsonify }},
      "name": {{ meta_title | jsonify }},
      "headline": {{ page_headline | jsonify }},
      "description": {{ meta_description | jsonify }},
      "isPartOf": { "@id": {{ site.url | append: '/#website' | jsonify }} }{% if schema_page_type == 'ProfilePage' %},
      "mainEntity": { "@id": {{ site.url | append: '/#person' | jsonify }} }{% else %},
      "about": { "@id": {{ site.url | append: '/#person' | jsonify }} },
      "author": { "@id": {{ site.url | append: '/#person' | jsonify }} }{% endif %}{% if meta_image_url != blank %},
      "primaryImageOfPage": {{ meta_image_url | jsonify }}{% endif %}{% if is_blog_post and page.date %},
      "datePublished": {{ page.date | date_to_xmlschema | jsonify }}{% endif %}
    }
  </script>
{% endif %}
